{
  "name": "zalo-bot-js",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Zalo Bot API.",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test:hello-bot": "npm run build && node ./dist/test/hello-bot.js",
    "test:token": "npm run build && node ./dist/test/check-token.js",
    "smoke": "node -e \"const sdk=require('./dist/src/index.js'); if(!sdk.Bot||!sdk.ApplicationBuilder||!sdk.filters){throw new Error('SDK exports are incomplete');} console.log('smoke ok');\"",
    "test": "npm run check && npm run build && npm run smoke",
    "start": "npm run build && node ./dist/production/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KaiyoDev/zalo-bot-js.git"
  },
  "keywords": [],
  "author": "KaiyoDev",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitepress": "^2.0.0-alpha.12"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "lowdb": "^7.0.1"
  }
}
